# YouTube動画自動化 - 環境変数設定

# ===================
# 画像生成（いずれか1つ）
# ===================

# Google Gemini API（画像生成 - デフォルト・推奨）
# https://aistudio.google.com/apikey でAPI Keyを取得
# Imagen 3: $0.03/枚
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API（画像生成 - 代替）
# https://platform.openai.com/ でAPI Keyを取得
# DALL-E 3: $0.04/枚
OPENAI_API_KEY=your_openai_api_key_here

# Replicate API（画像生成 - 代替）
# https://replicate.com/ でアカウント作成後、API Tokenを取得
# SDXL: 従量課金
REPLICATE_API_TOKEN=your_replicate_api_token_here

# ===================
# ナレーション生成
# ===================

# ElevenLabs API（ナレーション生成）
# https://elevenlabs.io/ でアカウント作成後、API Keyを取得
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_preferred_voice_id

# YouTube Data API
# Google Cloud Consoleで認証情報を作成
# OAuth 2.0 クライアントIDをダウンロードしてclient_secrets.jsonとして保存
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# 出力設定
OUTPUT_DIR=./output
TEMP_DIR=./temp

# 動画設定
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=30
VIDEO_BITRATE=8M

# 音声設定
AUDIO_BITRATE=192k
AUDIO_SAMPLE_RATE=44100
